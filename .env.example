# ── vLLM ─────────────────────────────────────────────────────────────────────
# Адрес vLLM сервера (выбрать нужный вариант):
VLLM_BASE_URL=http://IP:8000/v1        # vLLM на хосте (Linux Docker)
# VLLM_BASE_URL=http://host.docker.internal:8000/v1  # Docker Desktop / Win / Mac
# VLLM_BASE_URL=http://192.168.1.50:8000/v1         # vLLM на другом сервере

# Имя модели — точно как в --model при запуске vLLM
VLLM_MODEL=Qwen/Qwen3.5-35B-A3B-GPTQ-Int4
# API-ключ vLLM. Если запущен без --api-key — оставить EMPTY
VLLM_API_KEY=EMPTY

# ── OWUI ──────────────────────────────────────────────────────────────────────
# API-ключ агента в OWUI (Settings → Account → API Keys)
OWUI_SERVICE_TOKEN=sk-your-owui-api-key-here

# Модель OWUI для delegate_to_owui (обычно та же, что VLLM_MODEL,
# если OWUI тоже подключён к этому vLLM)
OWUI_DELEGATE_MODEL=Qwen/Qwen3.5-35B-A3B-GPTQ-Int4

# ── GIS MCP Server (arcgis_mcp) ──────────────────────────────────────────
# arcgis_mcp использует FastMCP 3.x transport=http → Streamable HTTP на /mcp.
# URL всегда заканчивается на /mcp.
#
# Варианты:
#   http://arcgis-mcp:8000/mcp       ← контейнер в той же Docker-сети (рекомендуется)
#   http://172.17.0.1:8000/mcp       ← сервис на хосте (Linux Docker)
#   http://host.docker.internal:8000/mcp  ← Docker Desktop / Win / Mac
GIS_MCP_URL=http://arcgis-mcp:8000/mcp

# JWT-токен для arcgis_mcp (если сервер запущен с GIS_USERNAME/GIS_PASSWORD).
# Получить: POST /auth/token с username/password → взять access_token.
# Оставить пустым если аутентификация не включена.
GIS_MCP_TOKEN=

# ── Sub-Agent self-reference ──────────────────────────────────────────────
# URL этого же сервиса внутри Docker-сети.
# sub_agent tool использует его для рекурсивного вызова агента.
# В docker-compose имя контейнера резолвится автоматически.
AGENT_SELF_URL=http://pydantic-agent:8000
